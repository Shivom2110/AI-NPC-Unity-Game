#!/bin/bash
set -euo pipefail

# -------------------------------------------------------------------
# AI-NPC-Unity-Game: Local Learning Core Installer
# Creates folders + writes core Week-1 scripts into the correct paths.
# Run from repo root (the folder that contains Assets/).
# -------------------------------------------------------------------

REPO_ROOT="$(pwd)"

if [ ! -d "$REPO_ROOT/Assets" ]; then
  echo "❌ ERROR: Assets/ not found. Run this from the Unity project root."
  exit 1
fi

echo "✅ Repo root: $REPO_ROOT"
echo "📁 Creating folders..."

mkdir -p Assets/Scripts/Systems/Events
mkdir -p Assets/Scripts/Systems/Learning
mkdir -p Assets/Scripts/Systems/Persistence
mkdir -p Assets/Scripts/Systems/Dialogue
mkdir -p Assets/Scripts/UI
mkdir -p Assets/Resources/Configs

write_file () {
  local path="$1"
  cat > "$path" <<'EOF'
'"$2"'
EOF
}

echo "🧩 Writing scripts..."

# -------------------------------------------------------------------
# Assets/Scripts/Systems/Events/PlayerEventType.cs
# -------------------------------------------------------------------
cat > Assets/Scripts/Systems/Events/PlayerEventType.cs <<'EOF'
namespace AINPC.Systems.Events
{
    // Keep this list small at first; expand as you add mechanics.
    public enum PlayerEventType
    {
        None = 0,

        // Combat
        AttackHigh,
        AttackMid,
        AttackLow,
        DodgeLeft,
        DodgeRight,
        DodgeBack,
        Block,
        Parry,
        Heal,
        Wait,

        // Dialogue / Interaction
        TalkNice,
        TalkRude,
        TalkTrade,
        TalkThreaten,
        HelpNPC,
        StealNPC,
        AttackNPC,
    }
}
EOF

# -------------------------------------------------------------------
# Assets/Scripts/Systems/Events/PlayerEvent.cs
# -------------------------------------------------------------------
cat > Assets/Scripts/Systems/Events/PlayerEvent.cs <<'EOF'
using System;
using UnityEngine;

namespace AINPC.Systems.Events
{
    [Serializable]
    public class PlayerEvent
    {
        public PlayerEventType type;
        public long unixMs;

        // Optional context (leave empty if not applicable)
        public string npcId;
        public string bossId;

        // Optional freeform metadata (JSON-friendly)
        public string meta;

        public PlayerEvent(PlayerEventType type, string npcId = "", string bossId = "", string meta = "")
        {
            this.type = type;
            this.unixMs = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
            this.npcId = npcId ?? "";
            this.bossId = bossId ?? "";
            this.meta = meta ?? "";
        }

        public override string ToString()
        {
            return $"[{unixMs}] {type} npc={npcId} boss={bossId} meta={meta}";
        }
    }
}
EOF

# -------------------------------------------------------------------
# Assets/Scripts/Systems/Events/EventBus.cs
# -------------------------------------------------------------------
cat > Assets/Scripts/Systems/Events/EventBus.cs <<'EOF'
using System;

namespace AINPC.Systems.Events
{
    // Simple global pub/sub. No scene refs needed.
    public static class EventBus
    {
        public static event Action<PlayerEvent> OnPlayerEvent;

        public static void Publish(PlayerEvent e)
        {
            OnPlayerEvent?.Invoke(e);
        }
    }
}
EOF

# -------------------------------------------------------------------
# Assets/Scripts/Systems/Learning/MarkovPredictor.cs
# -------------------------------------------------------------------
cat > Assets/Scripts/Systems/Learning/MarkovPredictor.cs <<'EOF'
using System;
using System.Collections.Generic;
using System.Linq;
using AINPC.Systems.Events;

namespace AINPC.Systems.Learning
{
    [Serializable]
    public class MarkovPredictor
    {
        // transitionCounts[prev][next] = count
        private readonly Dictionary<PlayerEventType, Dictionary<PlayerEventType, int>> transitionCounts
            = new Dictionary<PlayerEventType, Dictionary<PlayerEventType, int>>();

        public void Record(PlayerEventType prev, PlayerEventType next)
        {
            if (prev == PlayerEventType.None || next == PlayerEventType.None) return;

            if (!transitionCounts.TryGetValue(prev, out var nextMap))
            {
                nextMap = new Dictionary<PlayerEventType, int>();
                transitionCounts[prev] = nextMap;
            }

            if (!nextMap.ContainsKey(next)) nextMap[next] = 0;
            nextMap[next] += 1;
        }

        public PredictionResult PredictNext(PlayerEventType last)
        {
            if (last == PlayerEventType.None) return PredictionResult.None();

            if (!transitionCounts.TryGetValue(last, out var nextMap) || nextMap.Count == 0)
                return PredictionResult.None();

            // Pick max count
            var best = nextMap.OrderByDescending(kv => kv.Value).First();
            int total = nextMap.Values.Sum();

            float confidence = total > 0 ? (float)best.Value / total : 0f;

            return new PredictionResult(best.Key, confidence, total);
        }

        // Export for saving (JSON-friendly)
        public Dictionary<string, Dictionary<string, int>> Export()
        {
            var data = new Dictionary<string, Dictionary<string, int>>();
            foreach (var (prev, nextMap) in transitionCounts)
            {
                var inner = new Dictionary<string, int>();
                foreach (var (next, count) in nextMap)
                    inner[next.ToString()] = count;

                data[prev.ToString()] = inner;
            }
            return data;
        }

        // Import for loading
        public void Import(Dictionary<string, Dictionary<string, int>> data)
        {
            transitionCounts.Clear();
            if (data == null) return;

            foreach (var (prevKey, inner) in data)
            {
                if (!Enum.TryParse(prevKey, out PlayerEventType prev)) continue;
                if (inner == null) continue;

                var nextMap = new Dictionary<PlayerEventType, int>();
                foreach (var (nextKey, count) in inner)
                {
                    if (!Enum.TryParse(nextKey, out PlayerEventType next)) continue;
                    nextMap[next] = Math.Max(0, count);
                }

                if (nextMap.Count > 0)
                    transitionCounts[prev] = nextMap;
            }
        }
    }

    [Serializable]
    public readonly struct PredictionResult
    {
        public readonly bool hasPrediction;
        public readonly PlayerEventType predicted;
        public readonly float confidence; // 0..1
        public readonly int sampleCount;  // total transitions observed from last

        public PredictionResult(PlayerEventType predicted, float confidence, int sampleCount)
        {
            this.hasPrediction = true;
            this.predicted = predicted;
            this.confidence = confidence;
            this.sampleCount = sampleCount;
        }

        public static PredictionResult None() => new PredictionResult(PlayerEventType.None, 0f, 0, false);

        private PredictionResult(PlayerEventType predicted, float confidence, int sampleCount, bool hasPrediction)
        {
            this.hasPrediction = hasPrediction;
            this.predicted = predicted;
            this.confidence = confidence;
            this.sampleCount = sampleCount;
        }
    }
}
EOF

# -------------------------------------------------------------------
# Assets/Scripts/Systems/Persistence/LocalSaveService.cs
# -------------------------------------------------------------------
cat > Assets/Scripts/Systems/Persistence/LocalSaveService.cs <<'EOF'
using System;
using System.IO;
using UnityEngine;

namespace AINPC.Systems.Persistence
{
    public static class LocalSaveService
    {
        private const string RootFolderName = "saves";

        public static void SaveJson(string key, string json)
        {
            try
            {
                EnsureRoot();
                string path = GetPath(key);
                File.WriteAllText(path, json);
            }
            catch (Exception ex)
            {
                Debug.LogError($"[LocalSaveService] Save failed for key='{key}': {ex}");
            }
        }

        public static string LoadJson(string key)
        {
            try
            {
                EnsureRoot();
                string path = GetPath(key);
                if (!File.Exists(path)) return null;
                return File.ReadAllText(path);
            }
            catch (Exception ex)
            {
                Debug.LogError($"[LocalSaveService] Load failed for key='{key}': {ex}");
                return null;
            }
        }

        public static void Save<T>(string key, T data)
        {
            // Unity JsonUtility requires serializable types with fields (not properties).
            string json = JsonUtility.ToJson(data, prettyPrint: true);
            SaveJson(key, json);
        }

        public static T Load<T>(string key, T fallback) where T : class
        {
            string json = LoadJson(key);
            if (string.IsNullOrWhiteSpace(json)) return fallback;

            try
            {
                var obj = JsonUtility.FromJson<T>(json);
                return obj ?? fallback;
            }
            catch (Exception ex)
            {
                Debug.LogError($"[LocalSaveService] JSON parse failed for key='{key}': {ex}");
                return fallback;
            }
        }

        private static void EnsureRoot()
        {
            string root = GetRoot();
            if (!Directory.Exists(root))
                Directory.CreateDirectory(root);
        }

        private static string GetRoot()
        {
            return Path.Combine(Application.persistentDataPath, RootFolderName);
        }

        private static string GetPath(string key)
        {
            // Key becomes filename
            return Path.Combine(GetRoot(), $"{key}.json");
        }
    }
}
EOF

# -------------------------------------------------------------------
# Assets/Scripts/Systems/Persistence/SaveKeys.cs
# -------------------------------------------------------------------
cat > Assets/Scripts/Systems/Persistence/SaveKeys.cs <<'EOF'
namespace AINPC.Systems.Persistence
{
    public static class SaveKeys
    {
        public const string PlayerProfile = "player_profile";
        public const string MarkovTransitions = "markov_transitions";

        public static string Npc(string npcId) => $"npc_{npcId}";
        public static string Boss(string bossId) => $"boss_{bossId}";
    }
}
EOF

echo "✅ Scripts written."

echo ""
echo "🔍 Next steps:"
echo "1) Open Unity and let it import the new scripts."
echo "2) Wire combat/dialogue actions to publish events via:"
echo "     AINPC.Systems.Events.EventBus.Publish(new AINPC.Systems.Events.PlayerEvent(AINPC.Systems.Events.PlayerEventType.AttackHigh));"
echo "3) (Optional) Commit the new files:"
echo "     git add Assets/Scripts/Systems Assets/Scripts/UI Assets/Resources/Configs"
echo "     git commit -m \"Add local event system, predictor, and local save service\""

echo ""
echo "🎉 Installer finished."
